{
  "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
  "version": 1,
  "newProjectRoot": "projects",
  "projects": {
    "angular-storybook": {
      "projectType": "application",
      "root": "",
      "sourceRoot": "src",
      "architect": {
        "storybook": {
          "builder": "@storybook/angular:start-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "angular-storybook:build-angular",
            "port": 6012,
            "compodoc": false
          }
        },
        "build-storybook": {
          "builder": "@storybook/angular:build-storybook",
          "options": {
            "configDir": ".storybook",
            "browserTarget": "angular-storybook:build-angular",
            "compodoc": false
          }
        },
        "build-angular": {
          "builder": "@angular-devkit/build-angular:browser",
          "options": {
            "outputPath": "dist",
            "index": "",
            "main": "",
            "tsConfig": "tsconfig.json"
          }
        }
      }
    }
  },
  "cli": {
    "analytics": false
  }
}

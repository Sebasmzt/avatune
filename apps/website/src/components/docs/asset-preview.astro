---
type SvgFactory = (props?: { color?: string }) => string

type Props = {
  svg: string | SvgFactory
  title: string
  size?: number
  hideCaption?: boolean
}

const { svg, title, size = 72, hideCaption = false } = Astro.props as Props

const resolvedSvg = typeof svg === 'function' ? svg({ color: '#1b0b47' }) : svg
---

<figure class="asset-preview" aria-label={title}>
  <div class="asset-preview__canvas" set:html={resolvedSvg} />
  {!hideCaption && <figcaption>{title}</figcaption>}
</figure>

<style>
  .asset-preview {
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
  }

  .asset-preview__canvas {
    width: 150px;
    height: 150px;
    padding: 0.5rem;
    border-radius: 0.75rem;
    background: radial-gradient(circle at top, #f7fafc, #e2e8f0);
    box-shadow: inset 0 1px 2px rgba(15, 23, 42, 0.12);
  }

  .asset-preview__canvas :global(svg) {
    width: 100%;
    height: 100%;
    display: block;
  }

  figcaption {
    font-size: 0.75rem;
    text-transform: capitalize;
  }
</style>


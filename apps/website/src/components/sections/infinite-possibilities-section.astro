---
import { TOTAL_COMBINATIONS } from '../../lib/infinite-possibilities-data'
import InfinitePossibilities from '../client/infinite-possibilities.svelte'
---

<section class="mx-auto max-w-5xl rounded-3xl border border-white/10 bg-linear-to-br from-pink-500/10 to-slate-900/80 p-6 sm:p-10 lg:p-12 shadow-2xl shadow-pink-500/10">
  <div class="space-y-8 text-center">
    <div class="space-y-3">
      <p class="text-sm font-semibold uppercase tracking-[0.3em] text-pink-200">Infinite Possibilities</p>
      <h2 class="text-3xl font-semibold text-white sm:text-4xl">Countless combinations at your fingertips</h2>
      <p class="text-lg text-slate-300">
        Across four curated packs you can mix roughly {TOTAL_COMBINATIONS.toLocaleString('en-US')} distinct avatars without touching a design tool.
      </p>
    </div>

    <InfinitePossibilities client:only totalCombinations={TOTAL_COMBINATIONS} />
  </div>
</section>



---
import PredictionPipeline from '../components/client/prediction-pipeline.svelte'
import FrameworkShowcaseSection from '../components/sections/framework-showcase-section.astro'
import HeroSection from '../components/sections/hero-section.astro'
import InfinitePossibilitiesSection from '../components/sections/infinite-possibilities-section.astro'
import '../styles/global.css'

const primaryDocsLink = '/welcome'
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Avatune — Build expressive avatars fast</title>
    <meta
      name="description"
      content="Design, theme, and ship production-ready avatars with Avatune’s frameworks, themes, and predictive tooling."
    />
  </head>
  <body class="bg-slate-950 text-white antialiased">
    <HeroSection primaryDocsLink={primaryDocsLink} />

    <main class="space-y-24 px-6 pb-24 sm:px-12 lg:px-16">
      <section class="mx-auto max-w-5xl space-y-12">
        <div class="space-y-4 text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-pink-200">Why Avatune?</p>
          <h2 class="text-3xl font-semibold text-white sm:text-4xl">Design system DNA, ready for avatars</h2>
          <p class="text-lg text-slate-300">
            Combine flavors, predictive engines, and framework bindings to stay in sync from Figma to production.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Unified asset pipeline</h3>
            <p class="mt-3 text-sm text-slate-300">
              Pick a theme, swap palettes, and compose layers without rebuilding exports thanks to shared design tokens.
            </p>
          </article>
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Predictive customization</h3>
            <p class="mt-3 text-sm text-slate-300">
              Feed simple inputs into AI-assisted predictors to suggest hair color, length, and skin tones that feel on brand.
            </p>
          </article>
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Framework-native APIs</h3>
            <p class="mt-3 text-sm text-slate-300">
              React hooks, Vue composables, Svelte actions, and zero-dependency Vanilla helpers ensure teams share one toolkit.
            </p>
          </article>
        </div>
      </section>

      <FrameworkShowcaseSection />

      <section class="mx-auto max-w-5xl space-y-12">
        <div class="space-y-4 text-center">
          <p class="text-sm font-semibold uppercase tracking-[0.25em] text-pink-200">Use Cases</p>
          <h2 class="text-3xl font-semibold text-white sm:text-4xl">Where you can use Avatune</h2>
          <p class="text-lg text-slate-300">
            From user profiles to placeholder images, Avatune adapts to any context where expressive avatars are needed.
          </p>
        </div>
        <div class="grid gap-6 md:grid-cols-3">
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Dynamic Profiles</h3>
            <p class="mt-3 text-sm text-slate-300">
              Generate unique, consistent avatars for user profiles that reflect identity through customizable attributes and AI-powered suggestions.
            </p>
          </article>
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Avatars</h3>
            <p class="mt-3 text-sm text-slate-300">
              Build avatar customization interfaces where users can mix and match components to create their perfect representation.
            </p>
          </article>
          <article class="rounded-2xl border border-white/10 bg-white/5 p-6 shadow-lg shadow-pink-400/10">
            <h3 class="text-xl font-semibold text-white">Avatar Placeholders</h3>
            <p class="mt-3 text-sm text-slate-300">
              Use seed-based generation to create deterministic avatar placeholders that load instantly without external image dependencies.
            </p>
          </article>
        </div>
      </section>
      <section class="mx-auto max-w-6xl px-2">
        <PredictionPipeline client:only />
      </section>

      <InfinitePossibilitiesSection />

      <section class="mx-auto max-w-5xl text-center">
        <div class="space-y-5">
          <p class="text-sm font-semibold uppercase tracking-[0.3em] text-pink-200">Docs preview</p>
          <h2 class="text-3xl font-semibold text-white">Ready to explore the full knowledge base?</h2>
          <p class="text-lg text-slate-300">
            Jump straight into the documentation to see implementation details, live code samples, and synced package guides.
          </p>
        </div>
        <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
          <a
            href={primaryDocsLink}
            class="inline-flex items-center justify-center rounded-full bg-white px-6 py-3 text-base font-semibold text-slate-950 transition hover:bg-pink-100"
          >
            Open documentation
          </a>
          <a
            href="/why-avatune"
            class="inline-flex items-center justify-center rounded-full border border-white/30 px-6 py-3 text-base font-semibold text-white transition hover:border-white"
          >
            Learn why Avatune
          </a>
        </div>
      </section>
    </main>

    <footer class="border-t border-white/10 px-6 py-10 text-center text-sm text-slate-400 sm:px-12 lg:px-16">
      <p>Made with ❤️ by the Avatune team. Looking for something else? Check out the docs.</p>
    </footer>

  </body>
</html>


{
  "name": "@avatune/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "biome check --write",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check-types": "turbo run check-types",
    "storybook": "turbo run storybook --filter=@avatune/predictor-storybook --filter=@avatune/react-storybook --filter=@avatune/vue-storybook --filter=@avatune/svelte-storybook --filter=@avatune/vanilla-storybook --filter=@avatune/storybook-root",
    "generate:assets-readme": "bun scripts/generate-assets-readme.ts",
    "generate:theme-readme": "bun scripts/generate-assets-theme-readme.ts",
    "generate:theme-website-docs": "bun scripts/generate-themes-mdx.ts",
    "generate:readme-and-website-docs": "bun scripts/generate-assets-theme-readme.ts && bun scripts/generate-themes-mdx.ts"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "ws": "^8.18.0"
  }
}

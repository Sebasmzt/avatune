{
  "name": "@avatune/root",
  "private": true,
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "check": "biome check --write",
    "lint": "biome lint --write",
    "format": "biome format --write",
    "check-types": "turbo run check-types",
    "storybook": "turbo run storybook --filter=@avatune/predictor-storybook --filter=@avatune/react-storybook --filter=@avatune/vue-storybook --filter=@avatune/svelte-storybook --filter=@avatune/vanilla-storybook --filter=@avatune/storybook-root",
    "generate:assets-readme": "bun scripts/generate-assets-readme.ts",
    "generate:theme-readme": "bun scripts/generate-assets-theme-readme.ts",
    "generate:theme-website-docs": "bun scripts/generate-themes-mdx.ts",
    "generate:readme-and-website-docs": "bun scripts/generate-assets-theme-readme.ts && bun scripts/generate-themes-mdx.ts",
    "generate:root-readme": "bun scripts/generate-root-readme.ts",
    "prepare": "husky"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.2.3",
    "@changesets/changelog-github": "^0.5.2",
    "@changesets/cli": "^2.29.8",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "turbo": "^2.5.8",
    "typescript": "5.9.3"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "bun@1.3.1",
  "workspaces": [
    "apps/*",
    "packages/core/*",
    "packages/assets/*",
    "packages/themes/*",
    "packages/renderers/*",
    "packages/predictors/*",
    "packages/rsbuild-plugins/*"
  ],
  "lint-staged": {
    "*.{js,ts,tsx,jsx,json,md,css,html,vue,svelte}": [
      "biome check --write --no-errors-on-unmatched"
    ]
  },
  "resolutions": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "ws": "^8.18.0"
  }
}

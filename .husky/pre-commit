#!/bin/sh

# Run lint-staged for format and lint checks
bunx lint-staged

# Check if generation scripts produce any changes
echo "Checking if generated files are up to date..."

bun run generate:root-readme
bun run generate:theme-readme

if ! git diff --quiet; then
  echo ""
  echo "Error: Generated files are out of date!"
  echo "Please run the generation scripts and commit the changes:"
  echo "  bun run generate:root-readme"
  echo "  bun run generate:theme-readme"
  echo ""
  git diff --stat
  exit 1
fi

echo "All generated files are up to date."

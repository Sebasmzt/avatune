{
  "extends": "@avatune/typescript-config/base",
  "compilerOptions": {
    "module": "ESNext",
    "moduleResolution": "bundler",
    "outDir": "dist",
    "rootDir": "src",
    "jsx": "react-jsx",
    "paths": {
      "@avatune/types": ["../types/dist/index.d.ts"],
      "@avatune/kyute-assets": ["../kyute-assets/dist/svg.d.ts"],
      "@avatune/kyute-assets/react": ["../kyute-assets/dist/react.d.ts"],
      "@avatune/kyute-assets/svelte": ["../kyute-assets/dist/svelte.d.ts"],
      "@avatune/kyute-assets/vue": ["../kyute-assets/dist/vue.d.ts"],
      "@avatune/theme-builder": ["../theme-builder/dist/index.d.ts"]
    }
  },
  "include": ["src"],
  "exclude": ["node_modules", "dist"]
}
